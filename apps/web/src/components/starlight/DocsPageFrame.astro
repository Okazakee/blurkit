---
import MobileMenuToggle from './DocsMobileMenuToggle.astro'

const { hasSidebar } = Astro.locals.starlightRoute
---

<div class="docs-shell">
  <header class="docs-topbar">
    <div class="docs-topbar__inner">
      <slot name="header" />
      {
        hasSidebar && (
          <div class="docs-topbar__tools">
            <MobileMenuToggle />
          </div>
        )
      }
    </div>
  </header>

  <div class="docs-body">
    {
      hasSidebar && (
        <nav class="docs-sidebar-nav print:hidden" aria-label={Astro.locals.t('sidebarNav.accessibleLabel')}>
          <button
            class="docs-sidebar-scrim"
            type="button"
            data-close-sidebar
            aria-label="Close navigation menu"
            aria-hidden="true"
            tabindex="-1"
          ></button>
          <div id="starlight__sidebar" class="docs-sidebar-pane">
            <div class="docs-sidebar-pane__inner">
              <slot name="sidebar" />
            </div>
          </div>
        </nav>
      )
    }

    <div class="docs-main-frame">
      <slot />
    </div>
  </div>
</div>

<script>
  const MOBILE_QUERY = '(max-width: 49.99rem)'
  const FOCUSABLE_SELECTOR = [
    'a[href]',
    'button:not([disabled])',
    'input:not([disabled])',
    'select:not([disabled])',
    'textarea:not([disabled])',
    '[tabindex]:not([tabindex="-1"])',
  ].join(',')

  const mediaQuery = window.matchMedia(MOBILE_QUERY)
  const body = document.body
  const topbarInner = document.querySelector('.docs-topbar__inner')
  const mainFrame = document.querySelector('.docs-main-frame')
  const sidebarNav = document.querySelector('.docs-sidebar-nav')
  const sidebarPane = sidebarNav?.querySelector('.docs-sidebar-pane')
  const scrim = sidebarNav?.querySelector('.docs-sidebar-scrim')

  let lastFocusedElement: HTMLElement | null = null

  const getToggle = () => document.querySelector('starlight-menu-button')
  const getToggleButton = () => getToggle()?.querySelector('button')
  const isMenuExpanded = () => body.hasAttribute('data-mobile-menu-expanded')

  const getFocusableElements = (container: ParentNode | null | undefined): HTMLElement[] => {
    if (!container) return []
    const focusables: HTMLElement[] = []
    Array.from(container.querySelectorAll(FOCUSABLE_SELECTOR)).forEach((el) => {
      if (!(el instanceof HTMLElement)) return
      if (el.getAttribute('aria-hidden') === 'true') return
      if (el.getAttribute('inert') !== null) return
      const style = window.getComputedStyle(el)
      if (style.display === 'none' || style.visibility === 'hidden') return
      focusables.push(el)
    })
    return focusables
  }

  const closeMenu = () => {
    const toggle = getToggle()
    toggle?.setAttribute('aria-expanded', 'false')
    getToggleButton()?.setAttribute('aria-expanded', 'false')
    body.toggleAttribute('data-mobile-menu-expanded', false)
  }

  const trapMenuFocus = (event: KeyboardEvent) => {
    if (!mediaQuery.matches || !isMenuExpanded() || event.key !== 'Tab') return
    const focusables = getFocusableElements(sidebarNav)
    if (!focusables.length) return
    const first = focusables[0]!
    const last = focusables[focusables.length - 1]!
    const active = document.activeElement

    if (event.shiftKey && active === first) {
      event.preventDefault()
      last.focus()
      return
    }

    if (!event.shiftKey && active === last) {
      event.preventDefault()
      first.focus()
    }
  }

  const updateInertBackground = (expanded: boolean) => {
    if (!(mainFrame instanceof HTMLElement)) return
    mainFrame.inert = expanded

    if (!(topbarInner instanceof HTMLElement)) return
    const menuButtonHost = getToggle()
    Array.from(topbarInner.children).forEach((child) => {
      if (!(child instanceof HTMLElement)) return
      if (child === menuButtonHost) return
      if (child.classList.contains('docs-topbar__tools')) return
      child.inert = expanded
    })
  }

  const syncMenuState = () => {
    const expanded = mediaQuery.matches && isMenuExpanded()
    if (scrim instanceof HTMLButtonElement) {
      scrim.tabIndex = expanded ? 0 : -1
      scrim.setAttribute('aria-hidden', String(!expanded))
    }

    updateInertBackground(expanded)

    if (!expanded) return
    const focusables = getFocusableElements(sidebarPane)
    focusables[0]?.focus()
  }

  if (sidebarNav) {
    sidebarNav.addEventListener('keydown', (event) => trapMenuFocus(event as KeyboardEvent))
  }

  mediaQuery.addEventListener('change', () => {
    if (!mediaQuery.matches) closeMenu()
    syncMenuState()
  })

  const observer = new MutationObserver(() => {
    if (isMenuExpanded()) {
      lastFocusedElement = document.activeElement instanceof HTMLElement ? document.activeElement : null
    } else if (lastFocusedElement) {
      lastFocusedElement.focus()
      lastFocusedElement = null
    }
    syncMenuState()
  })

  observer.observe(body, {
    attributes: true,
    attributeFilter: ['data-mobile-menu-expanded'],
  })

  syncMenuState()

  document.querySelectorAll('[data-close-sidebar]').forEach((button) => {
    button.addEventListener('click', closeMenu)
  })

  /* Only enable sidebar overflow when its content exceeds the viewport. */
  const syncSidebarOverflow = () => {
    if (!sidebarPane) return
    const navHeight = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--sl-nav-height')) || 0
    const available = window.innerHeight - navHeight - 16
    if (sidebarPane.scrollHeight > available) {
      sidebarPane.classList.add('docs-sidebar-pane--overflow')
    } else {
      sidebarPane.classList.remove('docs-sidebar-pane--overflow')
    }
  }

  const sidebarObserver = new ResizeObserver(() => syncSidebarOverflow())
  if (sidebarPane) sidebarObserver.observe(sidebarPane)
  window.addEventListener('resize', syncSidebarOverflow)
  syncSidebarOverflow()
</script>

<style>
  .docs-shell {
    min-height: 100vh;
  }

  .docs-topbar {
    position: sticky;
    top: 0;
    z-index: var(--sl-z-index-navbar);
    padding:
      calc(1rem + env(safe-area-inset-top))
      calc(1rem + env(safe-area-inset-right))
      1rem
      calc(1rem + env(safe-area-inset-left));
    backdrop-filter: blur(18px);
    background:
      linear-gradient(180deg, rgba(10, 13, 24, 0.92), rgba(10, 13, 24, 0.76));
    border-bottom: 1px solid rgba(166, 184, 255, 0.08);
  }

  .docs-topbar__inner {
    width: min(1380px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
  }

  .docs-body {
    width: min(1380px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
  }

  .docs-sidebar-nav {
    position: relative;
  }

  .docs-sidebar-pane {
    width: 100%;
  }

  .docs-sidebar-pane__inner {
    padding: 1.15rem var(--sl-sidebar-pad-x) 2rem;
  }

  .docs-main-frame {
    min-width: 0;
  }

  .docs-sidebar-scrim {
    display: none;
  }

  @media (min-width: 50rem) {
    .docs-body {
      grid-template-columns: var(--sl-sidebar-width) minmax(0, 1fr);
      align-items: start;
    }

    .docs-sidebar-pane {
      position: sticky;
      top: calc(var(--sl-nav-height) + 0.25rem);
      padding-inline-end: 0.25rem;
    }

    .docs-sidebar-pane--overflow {
      max-height: calc(100vh - var(--sl-nav-height) - 1rem);
      overflow-y: auto;
    }
  }

  .docs-topbar__tools {
    display: none;
  }

  @media (max-width: 49.99rem) {
    .docs-topbar__inner {
      align-items: center;
    }

    .docs-topbar__tools {
      display: inline-flex;
    }

    .docs-sidebar-nav {
      position: fixed;
      inset: 0;
      z-index: calc(var(--sl-z-index-navbar) - 1);
      pointer-events: none;
    }

    .docs-sidebar-scrim {
      display: block;
      position: absolute;
      inset: 0;
      background: rgba(4, 6, 12, 0.68);
      opacity: 0;
      transition: opacity 180ms ease;
      pointer-events: none;
    }

    .docs-sidebar-pane {
      position: absolute;
      top: var(--sl-nav-height);
      bottom: 0;
      left: 0;
      width: min(88vw, 22rem);
      background:
        linear-gradient(180deg, rgba(13, 17, 33, 0.98), rgba(8, 10, 18, 0.98));
      border-inline-end: 1px solid rgba(166, 184, 255, 0.08);
      transform: translateX(-104%);
      transition: transform 180ms ease;
      overflow-y: auto;
      pointer-events: auto;
    }

    :global(body[data-mobile-menu-expanded]) .docs-sidebar-nav {
      pointer-events: auto;
    }

    :global(body[data-mobile-menu-expanded]) .docs-sidebar-scrim {
      opacity: 1;
      pointer-events: auto;
    }

    :global(body[data-mobile-menu-expanded]) .docs-sidebar-pane {
      transform: translateX(0);
    }
  }
</style>
