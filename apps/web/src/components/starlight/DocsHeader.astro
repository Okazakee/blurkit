---
import DocsSearch from './DocsSearch.astro'
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro'
import { BLURKIT_NPM_VERSION_URL, BLURKIT_VERSION } from '../../utils/blurkit-version'

const { siteTitleHref, id } = Astro.locals.starlightRoute
const isDocsHome = id === 'docs'
const isQuickStart = id === 'docs/quick-start'
---

<div class="docs-header">
  <div class="docs-header__brand">
    <a class="site-brand" href={siteTitleHref}>
      <span class="site-brand-mark">bk</span>
      <span class="site-brand-copy">
        <strong>blurkit</strong>
        <span>Universal placeholder generation</span>
      </span>
    </a>
    <a class="site-version-chip site-version-chip--compact" href={BLURKIT_NPM_VERSION_URL}>
      v{BLURKIT_VERSION}
    </a>
  </div>

  <nav class="docs-header__links" aria-label="Primary">
    <a class:list={['docs-header__link', { 'is-current': isDocsHome }]} href="/docs/">Overview</a>
    <a class:list={['docs-header__link', { 'is-current': isQuickStart }]} href="/docs/quick-start/">Quick start</a>
    <a class="docs-header__link" href="/#live-demo">Live demo</a>
  </nav>

  <div class="docs-header__search">
    <DocsSearch />
  </div>

  <div class="docs-header__social" aria-label="External">
    <SocialIcons />
  </div>
</div>

<style>
  .docs-header {
    display: grid;
    grid-template-columns: auto auto minmax(16rem, 24rem) auto;
    align-items: center;
    gap: 1rem;
    width: 100%;
  }

  .docs-header__brand {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    min-width: 0;
  }

  .docs-header__links {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
  }

  .docs-header__link {
    color: var(--sl-color-gray-3);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 700;
  }

  .docs-header__link:hover,
  .docs-header__link.is-current {
    color: var(--sl-color-white);
  }

  .docs-header__search {
    min-width: 0;
  }

  .docs-header__social {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.8rem;
  }

  .docs-header__social :global(a) {
    color: var(--sl-color-gray-2);
  }

  .docs-header__social :global(a:hover) {
    color: var(--sl-color-white);
  }

  @media (max-width: 71.99rem) {
    .docs-header {
      grid-template-columns: auto minmax(14rem, 1fr) auto;
    }

    .docs-header__links {
      display: none;
    }
  }

  @media (max-width: 49.99rem) {
    .docs-header {
      display: flex;
      align-items: center;
      gap: 0.85rem;
    }

    .docs-header__brand {
      flex: 1;
      min-width: 0;
    }

    .docs-header__links,
    .docs-header__social {
      display: none;
    }

  }
</style>
