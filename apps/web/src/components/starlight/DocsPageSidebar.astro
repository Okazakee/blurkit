---
import TableOfContents from '@astrojs/starlight/components/TableOfContents.astro'

const hasToc = Boolean(Astro.locals.starlightRoute.toc)
---

{
  hasToc && (
    <div class="docs-page-sidebar">
      <div class="bk-panel docs-page-sidebar__panel">
        <TableOfContents />
      </div>
    </div>
  )
}

<style>
  .docs-page-sidebar {
    display: none;
  }

  .docs-page-sidebar__panel {
    padding: 1.15rem 1.1rem;
  }

  @media (min-width: 50rem) {
    .docs-page-sidebar {
      display: block;
    }
  }
</style>
