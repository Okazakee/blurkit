---
import SidebarPersister from '@astrojs/starlight/components/SidebarPersister.astro'
import SidebarSublist from '@astrojs/starlight/components/SidebarSublist.astro'

const { sidebar } = Astro.locals.starlightRoute
---

<div class="docs-sidebar">
  <div class="docs-sidebar__intro bk-panel">
    <span class="site-eyebrow">Reference-first</span>
    <p>Runtime guides, CLI workflows, API details, and production patterns for blurkit.</p>
    <a class="site-button site-button--ghost site-button--small" href="/docs/quick-start/">
      Start with quick start
    </a>
  </div>

  <SidebarPersister>
    <SidebarSublist sublist={sidebar} />
  </SidebarPersister>
</div>

<script>
  const closeMenu = () => {
    const toggle = document.querySelector('starlight-menu-button')
    if (!toggle) return
    toggle.setAttribute('aria-expanded', 'false')
    toggle.querySelector('button')?.setAttribute('aria-expanded', 'false')
    document.body.toggleAttribute('data-mobile-menu-expanded', false)
  }

  document.querySelectorAll('.docs-sidebar a').forEach((link) => {
    link.addEventListener('click', closeMenu)
  })
</script>

<style>
  .docs-sidebar {
    display: grid;
    gap: 1rem;
  }

  .docs-sidebar__intro {
    display: grid;
    gap: 0.9rem;
  }

  .docs-sidebar__intro p {
    color: var(--bk-muted);
    font-size: 0.95rem;
  }

  .docs-sidebar :global(ul) {
    list-style: none;
    padding: 0;
  }

  .docs-sidebar :global(.top-level) {
    display: grid;
    gap: 0.9rem;
  }

  .docs-sidebar :global(details) {
    border-radius: 1rem;
    border: 1px solid rgba(166, 184, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.4rem;
  }

  .docs-sidebar :global(summary) {
    padding: 0.55rem 0.65rem;
    color: var(--sl-color-white);
  }

  .docs-sidebar :global(.group-label) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .docs-sidebar :global(ul ul) {
    display: grid;
    gap: 0.3rem;
    padding: 0.25rem 0.15rem 0.2rem 0.75rem;
  }

  .docs-sidebar :global(ul ul li) {
    margin-inline-start: 0;
    border-inline-start: 1px solid rgba(166, 184, 255, 0.1);
    padding-inline-start: 0.8rem;
  }

  .docs-sidebar :global(a) {
    border-radius: 0.8rem;
    color: var(--sl-color-gray-2);
    padding: 0.55rem 0.7rem;
  }

  .docs-sidebar :global(a:hover) {
    background: rgba(255, 255, 255, 0.04);
  }

  .docs-sidebar :global([aria-current='page']) {
    background: linear-gradient(135deg, rgba(126, 105, 255, 0.22), rgba(99, 223, 246, 0.12));
    border: 1px solid rgba(103, 236, 255, 0.18);
    color: var(--sl-color-white);
  }
</style>
