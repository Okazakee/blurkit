---
import '../styles/site.css'
import { BlurDemo } from '../components/BlurDemo'

const siteUrl = 'https://blurkit.dev'
const title = 'blurkit - Universal Placeholder Generation'
const description =
  'Generate BlurHash and ThumbHash placeholders across Node, browser, and edge.'
const canonicalUrl = `${siteUrl}/`
const socialImage = `${siteUrl}/social-card.svg`
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'blurkit',
  url: siteUrl,
  description,
  inLanguage: 'en',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/docs/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}
---

<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0a16" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;700;800&display=swap"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="site-skip-link" href="#main-content">Skip to main content</a>
    <div class="site-shell">
      <main class="site-main" id="main-content">
        <header class="site-header">
          <a class="site-brand" href="/">
            <span class="site-brand-mark">bk</span>
            <span class="site-brand-copy">
              <strong>blurkit</strong>
              <span>Universal placeholder generation</span>
            </span>
          </a>

          <nav class="site-nav" aria-label="Primary">
            <a class="site-nav-link" href="/docs/">Docs</a>
            <a class="site-nav-link" href="/docs/quick-start/">Quick start</a>
          </nav>
        </header>

        <section class="site-hero">
          <div class="site-copy">
            <span class="site-eyebrow">Universal blur placeholders</span>
            <h1 class="site-title">
              Image in.
              <br />
              Placeholder data URL out.
            </h1>
            <p>
              Generate BlurHash or ThumbHash placeholders across Node, browser, and edge, then inspect the output in the live demo below.
            </p>

            <div class="site-actions">
              <a class="site-button site-button--primary" href="#live-demo">Open the live demo</a>
            </div>
          </div>

          <aside class="site-panel site-stack">
            <div>
              <h2>Install</h2>
              <pre class="site-code"><code>pnpm add blurkit
pnpm add sharp</code></pre>
            </div>

            <div>
              <h2>Node quick start</h2>
              <pre class="site-code"><code>{`import { encode } from 'blurkit/node'

const result = await encode('./public/hero.jpg', {
  size: 32,
})

console.log(result.dataURL)`}</code></pre>
            </div>
          </aside>
        </section>

        <section class="site-section">
          <div class="site-section-header">
            <h2>Core features</h2>
            <p>
              blurkit covers the practical placeholder workflow: runtime-specific entrypoints, two algorithms, batch APIs, CLI tooling, manifest helpers, and a Node cache helper.
            </p>
          </div>

          <div class="site-grid">
            <article class="site-card site-card--stagger-1">
              <span class="site-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M5 8.5 12 3l7 5.5v7L12 21l-7-5.5v-7Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
                  <path d="M8.5 11h7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                </svg>
              </span>
              <h3>Runtime entrypoints</h3>
              <p>Import <span class="site-inline-code">blurkit/node</span>, <span class="site-inline-code">blurkit/browser</span>, or <span class="site-inline-code">blurkit/edge</span> explicitly when runtime behavior matters.</p>
            </article>
            <article class="site-card site-card--stagger-2">
              <span class="site-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <rect x="4" y="5" width="16" height="14" rx="3" fill="none" stroke="currentColor" stroke-width="1.8"></rect>
                  <path d="M8 12h8M8 15h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                </svg>
              </span>
              <h3>BlurHash and ThumbHash</h3>
              <p>Switch between the two shipped algorithms without changing the rest of your encode flow.</p>
            </article>
            <article class="site-card site-card--stagger-3">
              <span class="site-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M7 4.5h7l4 4v11H7z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
                  <path d="M14 4.5v4h4M9.5 12h5M9.5 15h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
              <h3>Ready-to-use result</h3>
              <p>Each encode returns a <span class="site-inline-code">dataURL</span>, the raw hash, placeholder dimensions, and source metadata.</p>
            </article>
            <article class="site-card">
              <span class="site-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M6 8h12M6 12h8M6 16h10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                  <path d="M17 6.5h.01M19 6.5h.01" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"></path>
                </svg>
              </span>
              <h3>Batch encoding</h3>
              <p>Use <span class="site-inline-code">encodeMany()</span> when one job needs placeholders for many images at once.</p>
            </article>
            <article class="site-card">
              <span class="site-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M7 4.5h7l4 4v11H7z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"></path>
                  <path d="M14 4.5v4h4M9.5 12h5M9.5 15h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
              <h3>CLI and manifests</h3>
              <p>Generate single-image JSON from the CLI or write folder manifests for build-time and import workflows.</p>
            </article>
            <article class="site-card">
              <span class="site-card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M6 7.5h12v9H6z" fill="none" stroke="currentColor" stroke-width="1.8" rx="2"></path>
                  <path d="M9 11.5h6M9 14.5h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                </svg>
              </span>
              <h3>Node cache helper</h3>
              <p>Reuse work in Node pipelines with the built-in in-memory cache exposed from <span class="site-inline-code">blurkit/node</span>.</p>
            </article>
          </div>
        </section>

        <section class="site-section" id="live-demo">
          <BlurDemo client:load />
        </section>
      </main>

      <footer class="site-footer">
        <div class="site-footer-card">
          <p>blurkit is an open-source toolkit for runtime-aware placeholder generation.</p>
          <nav class="site-footer-links" aria-label="Footer">
            <a href="/docs/">Docs</a>
            <a href="https://github.com/okazakee/blurkit">GitHub</a>
            <a href="https://www.npmjs.com/package/blurkit">npm</a>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
