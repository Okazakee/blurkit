---
import '../styles/site.css'
---

<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 - blurkit</title>
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <a class="site-skip-link" href="#main-content">Skip to main content</a>
    <div class="site-shell">
      <main class="site-main site-section--flush" id="main-content">
        <header class="site-header">
          <a class="site-brand" href="/">
            <span class="site-brand-mark">bk</span>
            <span class="site-brand-copy">
              <strong>blurkit</strong>
              <span>Universal placeholder generation</span>
            </span>
          </a>
        </header>

        <section class="site-section site-section--flush">
          <div class="site-section-header">
            <span class="site-eyebrow">Page not found</span>
            <h1 class="site-page-title">This route does not exist.</h1>
            <p>
              The page may have moved, or the URL may be wrong. Use the docs index or head back to the homepage.
            </p>
          </div>

          <div class="site-actions">
            <a class="site-button site-button--primary" href="/">
              Back to homepage
            </a>
            <a class="site-button site-button--ghost" href="/docs/">
              Open docs
            </a>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
