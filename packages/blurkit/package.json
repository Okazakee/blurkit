{
  "name": "blurkit",
  "version": "0.1.3",
  "type": "module",
  "bin": {
    "blurkit": "dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/root-node.d.ts",
  "exports": {
    ".": {
      "types": "./dist/root-node.d.ts",
      "browser": {
        "import": "./dist/root-browser.js",
        "require": "./dist/root-browser.cjs"
      },
      "worker": {
        "import": "./dist/root-edge.js",
        "require": "./dist/root-edge.cjs"
      },
      "node": {
        "import": "./dist/root-node.js",
        "require": "./dist/root-node.cjs"
      },
      "default": {
        "import": "./dist/root-edge.js",
        "require": "./dist/root-edge.cjs"
      }
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "import": "./dist/edge.js",
      "require": "./dist/edge.cjs"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js",
      "require": "./dist/cloudflare.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "description": "Universal image placeholder generation for Node, Bun, browser, and edge runtimes.",
  "homepage": "https://blurkit.okazakee.dev",
  "bugs": {
    "url": "https://github.com/Okazakee/blurkit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Okazakee/blurkit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "blurhash": "^2.0.5",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "thumbhash": "^0.1.1"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  },
  "peerDependencies": {
    "sharp": "^0.34.5"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  }
}
